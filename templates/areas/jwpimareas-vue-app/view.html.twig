{% set vueAppKey = pimcore_input('vueAppKey') %}
{% set waitSpinner = pimcore_checkbox('waitSpinner').isChecked() %}
{% set anchor = pimcore_input('anchor').getData() %}

{% if editmode %}
    <div class="flex">
        <div class="pr-3">
            {{ 'jwPimAreas.vueApp.name' | trans({}, 'admin', editorLanguage) }}:
        </div>
        <div class="flex-1 font-extra-bold">
            {{ vueAppKey.getData() | raw }}
        </div>
        {% if anchor is not empty %}
            <div class="pl-4 pr-3">
                {{ 'jwPimAreas.anchor.name' | trans({}, 'admin', editorLanguage) }}:
            </div>
            <div class="flex-1 font-extra-bold">
                #{{ anchor | raw }}
            </div>
        {% endif %}
    </div>
    <div>{{ vueAppKey | raw }}</div>
{% elseif vueAppKey.getData() is not empty %}
    <div data-vue="{{ vueAppKey.getData() | raw }}"{{ anchor ? ' id="' ~ anchor ~ '"' : '' }}>
        {% if waitSpinner %}
            <div class="text-center">
                <svg class="inline w-24 h-24 animate-spin" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                    <path d="M0 0h24v24H0z" fill="none"/>
                    <path fill="#fff" d="M17.65 6.35C16.2 4.9 14.21 4 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08c-.82 2.33-3.04 4-5.65 4-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z"/>
                </svg>
            </div>
        {% endif %}
    </div>
{% endif %}
