<!DOCTYPE html>
<html class="scroll-smooth" lang="de-DE">
<head>
    <meta charset="utf-8">
    <meta http-equiv="x-ua-compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="robots" content="noindex,nofollow,noodp,noydir,noarchive">
    <meta name="imagetoolbar" content="false">
    <meta name="format-detection" content="telephone=no">
    <meta name="theme-color" content="{{ jwPimAreas_themeColor | default('#000') | raw }}">

    {{ encore_entry_script_tags('alena') }}
    {{ encore_entry_link_tags('alena') }}
    {% if editmode %}
        {{ encore_entry_link_tags('editmode') }}
    {% endif %}
</head>
<body class="antialiased {{ editmode ? 'editmode' : '' }}">
{% block content %}{% endblock %}
</body>
</html>
